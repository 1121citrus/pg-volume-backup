rules:
  # Efficiency below this percentage fails the check.
  lowestEfficiency: 0.9

  # Absolute wasted bytes above this threshold fails the check.
  # Disabled: `apk upgrade` on Alpine unavoidably overwrites base-image files
  # (old versions remain in the base layer), which Dive counts as wasted space.
  highestWastedBytes: disabled

  # Percentage of wasted user-layer space above this threshold fails the check.
  # Default is 0.1 (10%).  Relaxed to 0.20: `apk upgrade` replaces Alpine base
  # files, registering as layer waste.  20% provides a buffer for that while
  # still catching genuinely bloated images.
  highestUserWastedPercent: 0.20
