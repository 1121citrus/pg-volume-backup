#!/usr/bin/env bash

# healthcheck — verify crond is running and the crontab is configured.
#
# Copyright (C) 2026 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later

ENV="${ENV:-${HOME:-/root}/.env}"
# shellcheck disable=SC1090
[[ -r "${ENV}" ]] && source "${ENV}"
COMMAND="${COMMAND:-/usr/local/bin/backup}"

crond_running=false
if pidof crond > /dev/null 2>&1; then
    crond_running=true
elif pgrep -x crond > /dev/null 2>&1; then
    crond_running=true
fi

if ! "${crond_running}"; then
    echo "healthcheck: crond is not running" >&2
    exit 1
fi

crontab_path="/var/spool/cron/crontabs/$(id -un)"
if ! grep -qF "${COMMAND}" "${crontab_path}" 2>/dev/null; then
    echo "healthcheck: crontab at ${crontab_path} missing ${COMMAND} entry" >&2
    exit 1
fi

exit 0
