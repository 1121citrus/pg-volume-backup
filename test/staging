    printf '  running Trivy scan on %s...\n' "${IMAGE}" >&2

    local result=0
    docker run --rm \
        -v "${_scan_tar}:/scan.tar:ro" \
        -v "${TRIVY_CACHE_VOLUME}:/root/.cache/trivy" \
        "${TRIVY_IMAGE}:${TRIVY_TAG}" image \
            --quiet \
            --no-progress \
            --exit-code 1 \
            --ignore-unfixed \
