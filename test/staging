#!/usr/bin/env bash

# test/staging — functional tests for pg-volume-backup against live AWS.
#
# Copyright (C) 2026 James Hanlon [mailto:jim@hanlonsoftware.com]
# SPDX-License-Identifier: AGPL-3.0-or-later
#
# These tests exercise pg-volume-backup end-to-end with no stubs.
# Tests that require a live S3 bucket are skipped (not failed) when
# AWS_S3_BUCKET_NAME is unset or AWS credentials are unavailable.
#
# No PostgreSQL instance is required: the end-to-end test backs up two
# synthetic raw-volume directories and verifies the resulting S3 objects.
#
# IAM permissions required:
#   Smoke tests (test_staging_dryrun):
#     None — dry-run makes no API calls
#   End-to-end correctness test (test_staging_backup_e2e):
#     On arn:aws:s3:::test.pg-volume-backup-*:
#       s3:CreateBucket, s3:DeleteBucket
#       s3:PutObject, s3:GetObject, s3:ListBucket, s3:DeleteObject
#
# SYNOPSIS
#   test/staging [options] [IMAGE]
#
# OPTIONS
#   IMAGE                     Docker image to test (positional; also --image)
#   --image IMAGE             Docker image to test (env: IMAGE)
#   --bucket BUCKET           S3 bucket name (env: AWS_S3_BUCKET_NAME)
#   --aws-config FILE         AWS config file path
#                             (env: AWS_CONFIG_FILE;
#                             default: ~/.secrets/aws-config)
#   --aws-credentials FILE    AWS credentials file path
#                             (env: AWS_CREDENTIALS_FILE;
#                             default: ~/.secrets/aws-credentials)
#   --scan                    Run Trivy HIGH/CRITICAL scan on the image
#                             (env: STAGING_SCAN; default: true)
#   --no-scan                 Skip Trivy scan; implies --no-advise unless
#                             --advise is given explicitly
#   --dryrun                  Enable dry-run mode for backup tests
#                             (env: DRYRUN; default: false)
#   --no-dryrun               Disable dry-run mode (default)
#   --no-coverage             Skip kcov coverage report (advisory only)
#   --advise [LIST]           Run advisory scans: coverage,grype,scout,dive,all
#                             (default list when LIST omitted: grype,scout)
#   --no-advise               Disable all advisory scans
#   --cache RULES             Scanner DB cache controls; RULES is semicolon-
#                             separated key=targets pairs; keys: reset,
#                             skip-update; targets: trivy,grype,all
#                             e.g. 'reset=all' or 'skip-update=grype'
#   --yes                     Skip the confirmation prompt
#   --skip-e2e                Skip test_staging_backup_e2e and
#                             test_staging_cron_backup_e2e
#   --skip-cron               Skip all cron service-mode tests
#   --test TEST               Run only the named test function
#   -h, --help                Print this message and exit
#
# ENVIRONMENT
#   IMAGE                Docker image to test
#   AWS_S3_BUCKET_NAME   S3 bucket name shown in the preflight summary;
#                        the e2e test creates its own transient bucket
#   AWS_CONFIG_FILE      Path to AWS config file
#   AWS_CREDENTIALS_FILE Path to AWS credentials file
#   AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY
#                        Inline credentials (alternative to config/credentials files)
#   DRYRUN               true = dry-run mode (default: false)
#   STAGING_SCAN         true/false — controls Trivy scan (default: true)
#   DOCKER_RUN_ARGS      Extra flags appended to every docker run invocation
#
# EXAMPLES
#   # AWS-independent smoke tests (no credentials needed):
#   test/staging 1121citrus/pg-volume-backup:latest
#
#   # Quick iteration — skip Trivy scan:
#   test/staging --no-scan 1121citrus/pg-volume-backup:latest
#
#   # Full suite with all advisory scans and fresh scanner DBs:
#   test/staging --no-dryrun --cache reset=all --advise all \
#       --aws-config ~/.secrets/aws-config \
#       1121citrus/pg-volume-backup:latest
#
#   # Run all three advisory scanners:
#   test/staging --advise grype,scout,dive 1121citrus/pg-volume-backup:latest
#
#   # Reset scanner DB caches for this run, then skip Grype DB update:
#   test/staging --cache 'reset=all;skip-update=grype' \
#       1121citrus/pg-volume-backup:latest
#
#   # Skip confirmation prompt (CI / scripted use):
#   test/staging --yes 1121citrus/pg-volume-backup:latest
#
#   # Run only the end-to-end correctness test:
#   test/staging --test test_staging_backup_e2e \
#       1121citrus/pg-volume-backup:latest
#
#   # Skip e2e test when credentials lack s3:CreateBucket:
#   test/staging --skip-e2e 1121citrus/pg-volume-backup:latest
#
#   # Skip cron service-mode tests (avoids the 90s cron-fire wait):
#   test/staging --no-scan --skip-cron \
#       1121citrus/pg-volume-backup:latest

set -euo pipefail

# ---------------------------------------------------------------------------
# Defaults — overridden by environment variables, then by CLI flags.
# ---------------------------------------------------------------------------
IMAGE="${IMAGE:-}"
AWS_S3_BUCKET_NAME="${AWS_S3_BUCKET_NAME:-}"
AWS_CONFIG_FILE="${AWS_CONFIG_FILE:-}"
AWS_CREDENTIALS_FILE="${AWS_CREDENTIALS_FILE:-}"
DRYRUN="${DRYRUN:-false}"
_YES=false
_SKIP_E2E=false
_SKIP_CRON=false
_ONLY_TEST=""
_SCAN="${STAGING_SCAN:-true}"
_ADVISE_COVERAGE=false
_ADVISE_DIVE=false
_ADVISE_GRYPE=false
_ADVISE_SCOUT=false
_ADVISE_EXPLICIT=false   # set to true when --advise or --no-advise is passed
_CACHE_RESET_TRIVY=false
_CACHE_RESET_GRYPE=false
_CACHE_SKIP_UPDATE_TRIVY=false
_CACHE_SKIP_UPDATE_GRYPE=false

# Tool image refs — keep in sync with the top-level build script.
BATS_KCOV_IMAGE=1121citrus/bats-kcov
BATS_KCOV_TAG=latest
DIVE_IMAGE=wagoodman/dive
DIVE_TAG=v0.13.1
GRYPE_IMAGE=anchore/grype
GRYPE_TAG=v0.87.0
TRIVY_IMAGE=aquasec/trivy
TRIVY_TAG=0.62.1

# Named Docker volumes for scanner DB caches (avoid host-path coupling).
TRIVY_CACHE_VOLUME=pg-volume-backup-staging-trivy-cache
GRYPE_CACHE_VOLUME=pg-volume-backup-staging-grype-cache

_set_cache_targets() {
    local mode="$1" targets_csv="$2" target
    IFS=',' read -ra _tgts <<< "${targets_csv,,}"
    for target in "${_tgts[@]}"; do
        case "${target}" in
            trivy)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_TRIVY=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_TRIVY=true; fi
                ;;
            grype)
                if [[ "${mode}" == "reset" ]];       then _CACHE_RESET_GRYPE=true; fi
                if [[ "${mode}" == "skip-update" ]]; then _CACHE_SKIP_UPDATE_GRYPE=true; fi
                ;;
            all)
                if [[ "${mode}" == "reset" ]]; then
                    _CACHE_RESET_TRIVY=true; _CACHE_RESET_GRYPE=true
                fi
                if [[ "${mode}" == "skip-update" ]]; then
                    _CACHE_SKIP_UPDATE_TRIVY=true; _CACHE_SKIP_UPDATE_GRYPE=true
                fi
                ;;
            *) echo "Unknown cache target: ${target}" >&2; exit 1 ;;
        esac
    done
}

_parse_cache_rules() {
    local rules="$1" entry key value
    IFS=';' read -ra _rules <<< "${rules}"
    for entry in "${_rules[@]}"; do
        key="${entry%%=*}"; value="${entry#*=}"
        key="${key,,}"; key="${key// /}"; value="${value// /}"
        if [[ "${entry}" != *=* || -z "${key}" || -z "${value}" ]]; then
            echo "Invalid --cache rule: ${entry}" >&2; exit 1
        fi
        case "${key}" in
            reset|skip-update) _set_cache_targets "${key}" "${value}" ;;
            *) echo "Unknown --cache rule key: ${key}" >&2; exit 1 ;;
        esac
    done
}

_reset_cache_db() {
    local volume_name="$1"
    docker run --rm \
        -v "${volume_name}:/cache" \
        alpine:3.21 \
        sh -c "rm -rf /cache/* && mkdir -p /cache"
}

show_help() {
    # Extract header comment from SYNOPSIS through EXAMPLES (inclusive).
    sed -n '/^# SYNOPSIS/,/^set -/p' "$0" \
        | grep '^#' \
        | sed 's/^# \{0,1\}//'
}

setup() {
    [[ -n "${IMAGE}" ]] || {
        echo "ERROR: IMAGE is not set" >&2
        echo "       Pass it as a positional arg or use --image IMAGE" >&2
        return 1
    }
    docker image inspect "${IMAGE}" > /dev/null 2>&1 || {
        echo "ERROR: image not found locally: ${IMAGE}" >&2
        echo "       Pull or build it first: ./build --no-scan" >&2
        return 1
    }

    # Verify the image CMD is the expected service entrypoint.
    # A mismatched CMD indicates a stale or wrong image.
    local cmd
    cmd=$(docker inspect "${IMAGE}" \
              --format '{{json .Config.Cmd}}' 2>/dev/null || echo "")
    if [[ "${cmd}" != '["/usr/local/bin/startup"]' ]]; then
        echo "ERROR: unexpected CMD in ${IMAGE}" >&2
        echo "       Got:      ${cmd}" >&2
        echo "       Expected: [\"/usr/local/bin/startup\"]" >&2
        echo "       Rebuild: ./build --no-scan" >&2
        return 1
    fi

    # Verify the CLI binary exists in the image before running any test.
    if ! docker run --rm "${IMAGE}" \
            test -x /usr/local/bin/pg-volume-backup > /dev/null 2>&1; then
        echo "ERROR: /usr/local/bin/pg-volume-backup not found in ${IMAGE}" >&2
        echo "       Rebuild: ./build --no-scan" >&2
        return 1
    fi

    # Resolve the AWS config file path once so each test does not re-derive it.
    _aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"

    # The image runs as a non-root user (UID 10001).  A mode-600 config file
    # owned by the host user is unreadable by that UID inside the container.
    # Create a world-readable temp copy for the duration of the test run.
    _aws_cfg_mount="${_aws_cfg}"
    if [[ -r "${_aws_cfg}" ]]; then
        _aws_cfg_mount=$(mktemp /tmp/aws-config-staging-XXXXXX)
        cp "${_aws_cfg}" "${_aws_cfg_mount}"
        chmod 0644 "${_aws_cfg_mount}"
    fi

    # Resolve the AWS credentials file; create a world-readable temp copy
    # for the non-root container user, same as the config file above.
    _aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    _aws_creds_mount="${_aws_creds}"
    if [[ -r "${_aws_creds}" ]]; then
        _aws_creds_mount=$(mktemp /tmp/aws-credentials-staging-XXXXXX)
        cp "${_aws_creds}" "${_aws_creds_mount}"
        chmod 0644 "${_aws_creds_mount}"
    fi

    # Run pg-volume-backup with optional AWS credential mounts.
    # The caller is responsible for mounting BACKUP_ROOT volumes when needed.
    run_pg_volume_backup() {
        local aws_mounts=()
        [[ -r "${_aws_cfg_mount}" ]] && \
            aws_mounts+=(
                -v "${_aws_cfg_mount}:/run/secrets/aws-config:ro"
                -e "AWS_CONFIG_FILE=/run/secrets/aws-config"
            )
        [[ -r "${_aws_creds_mount}" ]] && \
            aws_mounts+=(
                -v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro"
                -e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials"
            )
        # shellcheck disable=SC2086
        docker run --rm ${DOCKER_RUN_ARGS:-} \
            -e "AWS_S3_BUCKET_NAME=${AWS_S3_BUCKET_NAME:-}" \
            -e "DRYRUN=${DRYRUN:-false}" \
            "${aws_mounts[@]}" \
            "${IMAGE}" /usr/local/bin/pg-volume-backup "$@" 2>&1
    }

    # Run an aws CLI command inside the image, bypassing the pg-volume-backup
    # CMD.  Used for bucket lifecycle operations in test_staging_backup_e2e.
    _aws() {
        local aws_mounts=() aws_env=()
        if [[ -r "${_aws_cfg_mount}" ]]; then
            aws_mounts+=(-v "${_aws_cfg_mount}:/run/secrets/aws-config:ro")
            aws_env+=(-e "AWS_CONFIG_FILE=/run/secrets/aws-config")
        fi
        if [[ -r "${_aws_creds_mount}" ]]; then
            aws_mounts+=(-v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro")
            aws_env+=(-e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials")
        fi
        # shellcheck disable=SC2086
        docker run --rm --entrypoint /usr/bin/aws \
            ${DOCKER_RUN_ARGS:-} \
            "${aws_mounts[@]}" \
            "${aws_env[@]}" \
            "${IMAGE}" "$@"
    }

    export _aws_cfg _aws_cfg_mount _aws_creds _aws_creds_mount
    export -f _aws run_pg_volume_backup

    # Create a shared image archive for Trivy, Grype, and Dive — avoids
    # mounting the Docker socket inside scanner containers, which hangs on
    # macOS Docker Desktop.
    _scan_tar=""
    if [[ "${_SCAN}" == "true" || "${_ADVISE_GRYPE}" == "true" \
            || "${_ADVISE_DIVE}" == "true" ]]; then
        _scan_tar=$(mktemp /tmp/staging-scan-XXXXXX)
        docker save "${IMAGE}" > "${_scan_tar}"
    fi
    export _scan_tar

    # Clean up temp files on exit (world-readable credential copies + scan archive).
    # shellcheck disable=SC2064
    trap 'rm -f "${_aws_cfg_mount}" "${_aws_creds_mount}" "${_scan_tar}"' EXIT
}

# _skip prints a SKIP notice, increments the shared skip counter, and returns 0
# so the test is not counted as a failure.
_SKIP_COUNT=0
_skip() {
    echo "SKIP '${FUNCNAME[1]}': $*"
    (( ++_SKIP_COUNT )) || true
}

# _aws_available returns 0 when AWS credentials are present.
_aws_available() {
    [[ -r "${_aws_cfg_mount:-/nonexistent}" ]] || \
    [[ -r "${_aws_creds_mount:-/nonexistent}" ]] || \
    [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]
}

# ── AWS-independent tests ─────────────────────────────────────────────────────
# These exercise CLI option parsing only; no S3 connection is attempted.

test_staging_help() {
    local output result=0
    output=$(run_pg_volume_backup --help 2>&1) || result=$?
    if [[ ${result} -eq 0 ]] && echo "${output}" | grep -q 'Usage:'; then
        echo "PASS '${FUNCNAME[0]}': --help exits 0 and prints usage"
    else
        echo "FAIL '${FUNCNAME[0]}': --help failed (exit=${result})"
        return 1
    fi
}

test_staging_version() {
    local output result=0
    output=$(run_pg_volume_backup --version 2>&1) || result=$?
    if [[ ${result} -eq 0 ]] && [[ -n "${output}" ]]; then
        echo "PASS '${FUNCNAME[0]}': --version exits 0 and prints: ${output}"
    else
        echo "FAIL '${FUNCNAME[0]}': --version failed (exit=${result})"
        return 1
    fi
}

test_staging_unknown_option() {
    local result=0
    run_pg_volume_backup --no-such-option > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero for unknown option"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero" \
             "for unknown option"
        return 1
    fi
}

test_staging_no_bucket() {
    # Run pg-volume-backup without AWS_S3_BUCKET_NAME; must exit non-zero.
    # Uses plain docker run (not run_pg_volume_backup) to avoid injecting the
    # caller's AWS_S3_BUCKET_NAME from the outer environment.
    local result=0
    # shellcheck disable=SC2086
    docker run --rm ${DOCKER_RUN_ARGS:-} \
        "${IMAGE}" /usr/local/bin/pg-volume-backup \
        > /dev/null 2>&1 || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero without AWS_S3_BUCKET_NAME"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero" \
             "without AWS_S3_BUCKET_NAME"
        return 1
    fi
}

test_staging_no_volumes() {
    # AWS_S3_BUCKET_NAME set, but BACKUP_ROOT contains no subdirectories.
    local tmpdir result=0
    tmpdir=$(mktemp -d /tmp/staging-novol-XXXXXX)
    chmod o+rx "${tmpdir}"

    # shellcheck disable=SC2086
    docker run --rm ${DOCKER_RUN_ARGS:-} \
        -e "AWS_S3_BUCKET_NAME=test-bucket" \
        -e "BACKUP_ROOT=/backup" \
        -v "${tmpdir}:/backup:ro" \
        "${IMAGE}" /usr/local/bin/pg-volume-backup \
        > /dev/null 2>&1 || result=$?
    rm -rf "${tmpdir}"

    if [[ ${result} -ne 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': exits non-zero with empty BACKUP_ROOT"
    else
        echo "FAIL '${FUNCNAME[0]}': should have exited non-zero" \
             "with empty BACKUP_ROOT"
        return 1
    fi
}

test_staging_dryrun() {
    # --dry-run with a synthetic volume and a mock bucket exits 0 and makes
    # no S3 calls.
    local tmpdir result=0 output
    tmpdir=$(mktemp -d /tmp/staging-dryrun-XXXXXX)
    mkdir -p "${tmpdir}/uploads"
    echo "test file" > "${tmpdir}/uploads/document.pdf"
    chmod -R o+rx "${tmpdir}"

    # shellcheck disable=SC2086
    output=$(docker run --rm ${DOCKER_RUN_ARGS:-} \
        -e "AWS_S3_BUCKET_NAME=test-bucket" \
        -e "BACKUP_ROOT=/backup" \
        -e "BACKUP_HOSTNAME=staging-test" \
        -v "${tmpdir}:/backup:ro" \
        "${IMAGE}" /usr/local/bin/pg-volume-backup --dry-run \
        2>&1) || result=$?
    rm -rf "${tmpdir}"

    if [[ ${result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': --dry-run exits 0 with synthetic volume"
    else
        echo "FAIL '${FUNCNAME[0]}': --dry-run exited non-zero (exit=${result})"
        printf '  -- output --\n' >&2
        printf '%s\n' "${output}" >&2
        return 1
    fi
}

# ── Cron service-mode tests ───────────────────────────────────────────────────
# These tests start the container via its CMD (/usr/local/bin/startup) and
# exercise the async service path: startup → crond → backup →
# pg-volume-backup.  Two of the three tests wait up to 90s for the first
# cron tick; use --skip-cron when fast iteration matters more than coverage.

# test_staging_cron_startup: service mode initializes correctly.
#
# Starts the container with the default @daily schedule so no backup fires
# during the test.  Verifies that startup writes the env file, installs the
# crontab, starts crond, and that the healthcheck probe returns 0.
test_staging_cron_startup() {
    local cid result=0
    # shellcheck disable=SC2086
    cid=$(docker run --detach \
        -e "AWS_S3_BUCKET_NAME=test-bucket" \
        -e "BACKUP_ROOT=/backup" \
        -e "CRON_EXPRESSION=@daily" \
        ${DOCKER_RUN_ARGS:-} \
        "${IMAGE}" 2>&1) || result=$?
    if [[ ${result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': could not start container" \
             "(exit=${result})"
        return 1
    fi
    # Use rm -f so cleanup works whether the container is running or exited.
    # shellcheck disable=SC2064
    trap "docker rm -f '${cid}' > /dev/null 2>&1 || true" RETURN

    # Allow startup to complete before probing.
    sleep 3

    # Check that the container is still running; a quick exit means startup
    # failed — report the logs and bail rather than misreporting as a
    # healthcheck failure.
    local running
    running=$(docker inspect \
        --format '{{.State.Running}}' "${cid}" 2>/dev/null \
        || echo "false")
    if [[ "${running}" != "true" ]]; then
        local logs
        logs=$(docker logs "${cid}" 2>&1 \
            || echo "(no logs — container already removed)")
        echo "FAIL '${FUNCNAME[0]}': container exited during startup"
        printf '  -- container logs --\n' >&2
        printf '%s\n' "${logs}" >&2
        return 1
    fi

    local hc_result=0
    docker exec "${cid}" /usr/local/bin/healthcheck \
        > /dev/null 2>&1 || hc_result=$?
    if [[ ${hc_result} -eq 0 ]]; then
        echo "PASS '${FUNCNAME[0]}': service mode started;" \
             "healthcheck passes"
    else
        local logs
        logs=$(docker logs "${cid}" 2>&1)
        echo "FAIL '${FUNCNAME[0]}': healthcheck failed" \
             "(exit=${hc_result})"
        printf '  -- container logs --\n' >&2
        printf '%s\n' "${logs}" >&2
        return 1
    fi
}

# test_staging_cron_dryrun: cron fires backup in service mode.
#
# Overrides COMMAND to invoke pg-volume-backup with --dry-run so no S3
# calls are made and no credentials are needed.  Sets CRON_EXPRESSION to
# every minute and polls container logs for the pg-volume-backup finish
# line, with a 90s timeout.
test_staging_cron_dryrun() {
    local tmpdir result=0
    tmpdir=$(mktemp -d /tmp/staging-cron-XXXXXX)
    mkdir -p "${tmpdir}/uploads"
    echo "test file" > "${tmpdir}/uploads/document.pdf"
    chmod -R o+rx "${tmpdir}"

    local cid
    # shellcheck disable=SC2086
    cid=$(docker run --detach \
        -e "AWS_S3_BUCKET_NAME=test-bucket" \
        -e "BACKUP_ROOT=/backup" \
        -e "BACKUP_HOSTNAME=staging-cron-test" \
        -e "CRON_EXPRESSION=* * * * *" \
        -e "COMMAND=/usr/local/bin/pg-volume-backup --dry-run" \
        -v "${tmpdir}:/backup:ro" \
        ${DOCKER_RUN_ARGS:-} \
        "${IMAGE}" 2>&1) || result=$?

    if [[ ${result} -ne 0 ]]; then
        rm -rf "${tmpdir}"
        echo "FAIL '${FUNCNAME[0]}': could not start container" \
             "(exit=${result})"
        return 1
    fi
    # shellcheck disable=SC2064
    trap "docker rm -f '${cid}' > /dev/null 2>&1 || true; rm -rf '${tmpdir}'" RETURN

    # Poll every 5s for up to 90s for evidence the backup completed.
    local fired=false elapsed=0
    while [[ ${elapsed} -lt 90 ]]; do
        sleep 5
        elapsed=$(( elapsed + 5 ))
        if docker logs "${cid}" 2>&1 \
                | grep -q '\[INFO\].*finish pg-volume-backup'; then
            fired=true
            break
        fi
    done

    if "${fired}"; then
        echo "PASS '${FUNCNAME[0]}': cron fired backup in service" \
             "mode (dry-run)"
    else
        local logs
        logs=$(docker logs "${cid}" 2>&1)
        echo "FAIL '${FUNCNAME[0]}': cron did not fire within 90s"
        printf '  -- container logs --\n' >&2
        printf '%s\n' "${logs}" >&2
        return 1
    fi
}

# test_staging_cron_backup_e2e: end-to-end backup correctness via cron.
#
# Mirrors test_staging_backup_e2e but exercises the async service path
# (startup → crond → backup → pg-volume-backup) instead of direct CLI
# invocation.  Creates a disposable bucket, starts the container in service
# mode with a 1-minute schedule, waits up to 90s for the first cron tick,
# then verifies 4 S3 objects (2 archives + 2 checksums for 2 volumes).
#
# Required IAM permissions (on test.pg-volume-backup-*):
#   s3:CreateBucket, s3:DeleteBucket, s3:PutObject, s3:GetObject,
#   s3:ListBucket, s3:DeleteObject
test_staging_cron_backup_e2e() {
    _aws_available || {
        _skip "AWS credentials not configured"
        return 0
    }

    local epoch test_bucket tmpdir
    epoch=$(date +%s)
    test_bucket="test.pg-volume-backup-${epoch}"
    tmpdir=$(mktemp -d /tmp/staging-cron-e2e-XXXXXX)

    # Always remove the transient bucket and temp dir on return.
    # shellcheck disable=SC2064
    trap "
        _aws s3 rb 's3://${test_bucket}' --force > /dev/null 2>&1 || true
        rm -rf '${tmpdir}'
    " RETURN

    printf '  creating transient test bucket s3://%s...\n' \
        "${test_bucket}" >&2
    _aws s3 mb "s3://${test_bucket}" > /dev/null 2>&1 || {
        echo "FAIL '${FUNCNAME[0]}': could not create bucket" \
             "(check s3:CreateBucket on test.pg-volume-backup-*)"
        return 1
    }

    mkdir -p "${tmpdir}/uploads" "${tmpdir}/data"
    echo "fake-pdf-content" > "${tmpdir}/uploads/document.pdf"
    echo "fake-data"        > "${tmpdir}/data/file.dat"
    chmod -R o+rx "${tmpdir}"

    local aws_mounts=()
    [[ -r "${_aws_cfg_mount}" ]] && \
        aws_mounts+=(
            -v "${_aws_cfg_mount}:/run/secrets/aws-config:ro"
            -e "AWS_CONFIG_FILE=/run/secrets/aws-config"
        )
    [[ -r "${_aws_creds_mount}" ]] && \
        aws_mounts+=(
            -v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro"
            -e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials"
        )

    printf '  starting service container (cron every minute)...\n' >&2
    local cid cid_result=0
    # shellcheck disable=SC2086
    cid=$(docker run --detach \
        -e "AWS_S3_BUCKET_NAME=${test_bucket}" \
        -e "BACKUP_ROOT=/backup" \
        -e "BACKUP_HOSTNAME=staging-cron-test" \
        -e "CRON_EXPRESSION=* * * * *" \
        -e "COMPRESSION=none" \
        -v "${tmpdir}:/backup:ro" \
        "${aws_mounts[@]}" \
        ${DOCKER_RUN_ARGS:-} \
        "${IMAGE}" 2>&1) || cid_result=$?
    if [[ ${cid_result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': could not start container" \
             "(exit=${cid_result})"
        return 1
    fi

    # Extend the RETURN trap to also remove the container.
    # shellcheck disable=SC2064
    trap "
        docker rm -f '${cid}' > /dev/null 2>&1 || true
        _aws s3 rb 's3://${test_bucket}' --force > /dev/null 2>&1 || true
        rm -rf '${tmpdir}'
    " RETURN

    # Poll every 5s for up to 90s for a completed backup.
    printf '  waiting for first cron tick (up to 90s)...\n' >&2
    local fired=false elapsed=0
    while [[ ${elapsed} -lt 90 ]]; do
        sleep 5
        elapsed=$(( elapsed + 5 ))
        if docker logs "${cid}" 2>&1 \
                | grep -q '\[INFO\].*finish backup'; then
            fired=true
            break
        fi
    done

    if ! "${fired}"; then
        local logs
        logs=$(docker logs "${cid}" 2>&1)
        echo "FAIL '${FUNCNAME[0]}': cron did not fire within 90s"
        printf '  -- container logs --\n' >&2
        printf '%s\n' "${logs}" >&2
        return 1
    fi

    # Verify object count: 2 volumes × 2 objects = 4 total.
    local count=0
    count=$(_aws s3 ls --recursive "s3://${test_bucket}/" \
                2>/dev/null | wc -l | tr -d ' ')

    if [[ "${count}" -eq 4 ]]; then
        echo "PASS '${FUNCNAME[0]}': ${count} objects in S3 after" \
             "cron backup (2 archives + 2 checksums for 2 volumes)"
    else
        local bk_logs
        bk_logs=$(docker logs "${cid}" 2>&1)
        echo "FAIL '${FUNCNAME[0]}': ${count} objects in S3 (expected 4)"
        printf 'Objects in bucket:\n' >&2
        _aws s3 ls --recursive "s3://${test_bucket}/" >&2 2>&1 || true
        printf 'Container logs:\n' >&2
        printf '%s\n' "${bk_logs}" >&2
        return 1
    fi
}

# ── AWS-dependent tests ───────────────────────────────────────────────────────

# test_staging_backup_e2e: end-to-end backup correctness test.
#
# Creates a disposable bucket named test.pg-volume-backup-<epoch>,
# backs up two synthetic volumes (uploads/ and data/) to it without GPG
# encryption or compression, then counts the resulting S3 objects.
#
# Each volume produces two objects: a .tar archive and a .tar.sha256
# companion.  Two volumes × 2 objects = 4 objects total.
#
# The bucket is always removed in a RETURN trap, even on failure.
# The Docker socket is NOT mounted, so no labeled containers are stopped —
# the raw-tar pipeline runs unconditionally.
#
# Required IAM permissions (on test.pg-volume-backup-*):
#   s3:CreateBucket, s3:DeleteBucket, s3:PutObject, s3:GetObject,
#   s3:ListBucket, s3:DeleteObject
test_staging_backup_e2e() {
    _aws_available || {
        _skip "AWS credentials not configured"
        return 0
    }

    local epoch test_bucket tmpdir
    epoch=$(date +%s)
    test_bucket="test.pg-volume-backup-${epoch}"
    tmpdir=$(mktemp -d /tmp/staging-e2e-XXXXXX)

    # Always remove the transient bucket and temp dir on return.
    # shellcheck disable=SC2064
    trap "
        _aws s3 rb 's3://${test_bucket}' --force > /dev/null 2>&1 || true
        rm -rf '${tmpdir}'
    " RETURN

    # ── Create bucket ─────────────────────────────────────────────────────────
    printf '  creating transient test bucket s3://%s...\n' \
        "${test_bucket}" >&2
    _aws s3 mb "s3://${test_bucket}" > /dev/null 2>&1 || {
        echo "FAIL '${FUNCNAME[0]}': could not create bucket" \
             "(check s3:CreateBucket on test.pg-volume-backup-*)"
        return 1
    }

    # ── Populate synthetic volumes ────────────────────────────────────────────
    # Two volume directories: uploads/ and data/.  One file each is
    # sufficient to exercise the full archive + upload pipeline.
    mkdir -p "${tmpdir}/uploads" "${tmpdir}/data"
    echo "fake-pdf-content" > "${tmpdir}/uploads/document.pdf"
    echo "fake-data"        > "${tmpdir}/data/file.dat"
    chmod -R o+rx "${tmpdir}"

    # ── Run backup ────────────────────────────────────────────────────────────
    local aws_mounts=()
    [[ -r "${_aws_cfg_mount}" ]] && \
        aws_mounts+=(
            -v "${_aws_cfg_mount}:/run/secrets/aws-config:ro"
            -e "AWS_CONFIG_FILE=/run/secrets/aws-config"
        )
    [[ -r "${_aws_creds_mount}" ]] && \
        aws_mounts+=(
            -v "${_aws_creds_mount}:/run/secrets/aws-credentials:ro"
            -e "AWS_SHARED_CREDENTIALS_FILE=/run/secrets/aws-credentials"
        )
    printf '  running backup to s3://%s...\n' "${test_bucket}" >&2
    local bk_output bk_result=0
    # shellcheck disable=SC2086
    bk_output=$(docker run --rm ${DOCKER_RUN_ARGS:-} \
        -e "AWS_S3_BUCKET_NAME=${test_bucket}" \
        -e "BACKUP_ROOT=/backup" \
        -e "BACKUP_HOSTNAME=staging-test" \
        -e "COMPRESSION=none" \
        -v "${tmpdir}:/backup:ro" \
        "${aws_mounts[@]}" \
        "${IMAGE}" /usr/local/bin/pg-volume-backup 2>&1) || bk_result=$?

    if [[ ${bk_result} -ne 0 ]]; then
        echo "FAIL '${FUNCNAME[0]}': pg-volume-backup exited" \
             "non-zero (${bk_result})"
        printf '  -- output --\n' >&2
        printf '%s\n' "${bk_output}" >&2
        return 1
    fi

    # ── Verify object count ───────────────────────────────────────────────────
    # 2 volumes × 2 objects each (.tar + .tar.sha256) = 4 objects total.
    local count=0
    count=$(_aws s3 ls --recursive "s3://${test_bucket}/" \
                2>/dev/null | wc -l | tr -d ' ')

    if [[ "${count}" -eq 4 ]]; then
        echo "PASS '${FUNCNAME[0]}': ${count} objects in S3" \
             "(2 archives + 2 checksums for 2 volumes)"
    else
        echo "FAIL '${FUNCNAME[0]}': ${count} objects in S3 (expected 4)"
        printf 'Objects in bucket:\n' >&2
        _aws s3 ls --recursive "s3://${test_bucket}/" >&2 2>&1 || true
        printf 'Backup output:\n' >&2
        printf '%s\n' "${bk_output}" >&2
        return 1
    fi
}

