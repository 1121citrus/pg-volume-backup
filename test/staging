# ---------------------------------------------------------------------------
# Test runner
# ---------------------------------------------------------------------------

run_tests() {
    local all_tests=(
        test_staging_help
        test_staging_version
        test_staging_unknown_option
        test_staging_trivy_scan
        test_staging_grype_advise
        test_staging_scout_advise
        test_staging_dive_advise
        test_staging_coverage_advise
        test_staging_no_bucket
        test_staging_no_volumes
        test_staging_dryrun
        test_staging_cron_startup
        test_staging_cron_dryrun
        test_staging_backup_e2e
        test_staging_cron_backup_e2e
    )

    # Apply --test, --skip-e2e, and --skip-cron filters.
    local tests=()
    if [[ -n "${_ONLY_TEST}" ]]; then
        local valid=false t
        for t in "${all_tests[@]}"; do
            [[ "${t}" == "${_ONLY_TEST}" ]] && valid=true && break
        done
        if ! "${valid}"; then
            echo "ERROR: unknown test '${_ONLY_TEST}'" >&2
            printf '       Available tests:\n' >&2
            printf '         %s\n' "${all_tests[@]}" >&2
            return 1
        fi
        tests=("${_ONLY_TEST}")
    else
        for t in "${all_tests[@]}"; do
            [[ "${t}" == "test_staging_backup_e2e" \
                && "${_SKIP_E2E}" == "true" ]] && continue
            [[ "${t}" == "test_staging_cron_backup_e2e" \
                && ("${_SKIP_E2E}" == "true" \
                    || "${_SKIP_CRON}" == "true") ]] && continue
            [[ ("${t}" == "test_staging_cron_startup" \
                || "${t}" == "test_staging_cron_dryrun") \
                && "${_SKIP_CRON}" == "true" ]] && continue
            tests+=("${t}")
        done
    fi

    setup || { echo "ERROR: Setup failed"; return 1; }

    if [[ "${_CACHE_RESET_TRIVY}" == "true" ]]; then
        echo "==> Cache: reset Trivy DB" >&2
        _reset_cache_db "${TRIVY_CACHE_VOLUME}"
    fi
    if [[ "${_CACHE_RESET_GRYPE}" == "true" ]]; then
        echo "==> Cache: reset Grype DB" >&2
        _reset_cache_db "${GRYPE_CACHE_VOLUME}"
    fi

    echo "Running staging tests for pg-volume-backup..."
    echo "================================================="
    echo "Image:  ${IMAGE}"
    if _aws_available; then
        echo "AWS:    credentials configured"
    else
        echo "AWS:    not configured — AWS-dependent tests will be skipped"
    fi
    [[ -n "${_ONLY_TEST}" ]]  && echo "Filter: --test ${_ONLY_TEST}"
    "${_SKIP_E2E}"            && echo "Filter: --skip-e2e"
    "${_SKIP_CRON}"           && echo "Filter: --skip-cron"
    echo "Scan:   ${_SCAN} (Trivy HIGH/CRITICAL)"
    echo "Advise: coverage=${_ADVISE_COVERAGE} dive=${_ADVISE_DIVE}" \
         "grype=${_ADVISE_GRYPE} scout=${_ADVISE_SCOUT}"
    echo "================================================="

    _SKIP_COUNT=0
    local passed=0 failed=0
    for t in "${tests[@]}"; do
        if "${t}"; then
            (( ++passed )) || true
        else
            (( ++failed )) || true
        fi
    done
    # Subtract skips from passed: skipped tests exit 0 but are not passes.
    passed=$(( passed - _SKIP_COUNT ))

    local total=${#tests[@]}
    echo "================================================="
    echo "Results: ${passed} passed, ${failed} failed," \
         "${_SKIP_COUNT} skipped (${total} run)"
    return "${failed}"
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() {
    require_option_value() {
        local option="$1"
        local value="${2:-}"
        if [[ -z "${value}" || "${value}" == --* ]]; then
            echo "Option ${option} requires a value" >&2
            echo "Run 'test/staging --help' for usage." >&2
            exit 1
        fi
    }

    # ── Option parsing ────────────────────────────────────────────────────────
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --image)
                require_option_value "$1" "${2:-}"
                IMAGE="$2"
                shift
                ;;
            --bucket)
                require_option_value "$1" "${2:-}"
                AWS_S3_BUCKET_NAME="$2"
                shift
                ;;
            --aws-config)
                require_option_value "$1" "${2:-}"
                AWS_CONFIG_FILE="$2"
                shift
                ;;
            --aws-credentials)
                require_option_value "$1" "${2:-}"
                AWS_CREDENTIALS_FILE="$2"
                shift
                ;;
            --scan)         _SCAN=true   ;;
            --no-scan)      _SCAN=false  ;;
            --dryrun)       DRYRUN=true  ;;
            --no-dryrun)    DRYRUN=false ;;
            --no-coverage)  _ADVISE_COVERAGE=false ;;
            --advise|--advice)
                _ADVISE_EXPLICIT=true
                if [[ $# -gt 1 && "$2" =~ \
                        ^(coverage|dive|grype|scout|all)(,(coverage|dive|grype|scout|all))*$ ]]; then
                    advisements="$2"; shift
                else
                    advisements="grype,scout"
                fi
                _ADVISE_COVERAGE=false
                _ADVISE_DIVE=false
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                IFS=',' read -ra adv_list <<< "$advisements"
                for adv in "${adv_list[@]}"; do
                    case "$adv" in
                        coverage) _ADVISE_COVERAGE=true ;;
                        dive)     _ADVISE_DIVE=true ;;
                        grype)    _ADVISE_GRYPE=true ;;
                        scout)    _ADVISE_SCOUT=true ;;
                        all) _ADVISE_COVERAGE=true; _ADVISE_DIVE=true
                             _ADVISE_GRYPE=true; _ADVISE_SCOUT=true ;;
                        *)   echo "Unknown advisement: $adv" >&2; exit 1 ;;
                    esac
                done
                ;;
            --no-advise)
                _ADVISE_COVERAGE=false
                _ADVISE_DIVE=false
                _ADVISE_GRYPE=false
                _ADVISE_SCOUT=false
                _ADVISE_EXPLICIT=true
                ;;
            --cache)
                [[ $# -ge 2 ]] || {
                    echo "option '${1}' requires an argument" >&2; exit 1; }
                _parse_cache_rules "$2"; shift
                ;;
            --yes)        _YES=true    ;;
            --skip-e2e)   _SKIP_E2E=true ;;
            --skip-cron)  _SKIP_CRON=true ;;
            --test)
                require_option_value "$1" "${2:-}"
                _ONLY_TEST="$2"
                shift
                ;;
            -h|--help)    show_help; exit 0 ;;
            -*)
                echo "Unknown option: $1" >&2
                echo "Run 'test/staging --help' for usage." >&2
                exit 1 ;;
            *)
                # First non-option positional arg is the image.
                if [[ -z "${IMAGE}" ]]; then
                    IMAGE="$1"
                else
                    echo "Unexpected argument: $1" >&2
                    exit 1
                fi ;;
        esac
        shift
    done

    # --no-scan implies --no-advise unless --advise was given explicitly.
    if [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        _ADVISE_COVERAGE=false
        _ADVISE_DIVE=false
        _ADVISE_GRYPE=false
        _ADVISE_SCOUT=false
    fi

    # Propagate resolved values so setup() and test functions see them.
    export IMAGE AWS_S3_BUCKET_NAME AWS_CONFIG_FILE AWS_CREDENTIALS_FILE DRYRUN
    export _YES _SKIP_E2E _SKIP_CRON _ONLY_TEST _SCAN
    export _ADVISE_COVERAGE _ADVISE_DIVE _ADVISE_GRYPE _ADVISE_SCOUT
    export _CACHE_RESET_TRIVY _CACHE_RESET_GRYPE
    export _CACHE_SKIP_UPDATE_TRIVY _CACHE_SKIP_UPDATE_GRYPE

    # ── Preflight summary ────────────────────────────────────────────────────
    local aws_cfg="${AWS_CONFIG_FILE:-${HOME}/.secrets/aws-config}"
    local aws_creds="${AWS_CREDENTIALS_FILE:-${HOME}/.secrets/aws-credentials}"
    local will_touch_aws=false
    { [[ -r "${aws_cfg}" ]] || [[ -r "${aws_creds}" ]] \
      || [[ -n "${AWS_ACCESS_KEY_ID:-}" ]]; } && \
        will_touch_aws=true

    echo "================================================================"
    echo " WARNING: test/staging exercises live infrastructure"
    echo "================================================================"
    echo ""
    echo "  Image:    ${IMAGE:-<not set>}"
    if [[ "${_SCAN}" == "true" ]]; then
        echo "  Scan:     Trivy HIGH/CRITICAL (--no-scan to skip)"
    else
        echo "  Scan:     skipped (--no-scan)"
    fi
    local _advise_any=false
    [[ "${_ADVISE_COVERAGE}" == "true" || "${_ADVISE_DIVE}" == "true" \
        || "${_ADVISE_GRYPE}" == "true" || "${_ADVISE_SCOUT}" == "true" ]] \
        && _advise_any=true
    if "${_advise_any}"; then
        local _advise_list=()
        [[ "${_ADVISE_COVERAGE}" == "true" ]] && _advise_list+=(coverage)
        [[ "${_ADVISE_DIVE}"     == "true" ]] && _advise_list+=(dive)
        [[ "${_ADVISE_GRYPE}"    == "true" ]] && _advise_list+=(grype)
        [[ "${_ADVISE_SCOUT}"    == "true" ]] && _advise_list+=(scout)
        local IFS=,
        echo "  Advise:   ${_advise_list[*]} (--no-advise to skip)"
    elif [[ "${_SCAN}" == "false" && "${_ADVISE_EXPLICIT}" == "false" ]]; then
        echo "  Advise:   skipped (implied by --no-scan; use --advise to enable)"
    else
        echo "  Advise:   skipped (--no-advise)"
    fi
    if [[ "${DRYRUN}" == "true" ]]; then
        echo "  Dry-run:  true — backup writes are suppressed"
    fi
    if "${_SKIP_CRON}"; then
        echo "  Cron:     skipped (--skip-cron)"
    else
        echo "  Cron:     enabled (cron tests wait up to 90s;" \
             "--skip-cron to skip)"
    fi
    echo ""

    if "${will_touch_aws}"; then
        echo "  E2E test: will CREATE and DELETE a transient bucket:"
        echo "            s3://test.pg-volume-backup-<epoch>"
        echo "            2 synthetic volumes are backed up and verified."
        echo "            Requires s3:CreateBucket + s3:PutObject +"
        echo "            s3:DeleteBucket on test.pg-volume-backup-*"
    else
        echo "  AWS:      not configured — AWS-dependent tests will be skipped"
    fi
    echo ""

    # ── Confirmation ──────────────────────────────────────────────────────────
    # Prompt only when real AWS will be touched; --yes skips for scripted use.
    if "${will_touch_aws}"; then
        if "${_YES}"; then
            echo "  (--yes: skipping confirmation prompt)"
            echo ""
        else
            printf 'Type "yes" to proceed, or press Enter to abort: '
            local response
            read -r response
            echo ""
            if [[ "${response}" != "yes" ]]; then
                echo "Aborted."
                return 1
            fi
        fi
    fi

    run_tests
}

[[ "${BASH_SOURCE[0]}" == "$0" ]] && main "$@"
